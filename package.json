{
  "name": "survey-landing",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node -r ./patch-readlink.js node_modules/next/dist/bin/next dev",
    "build": "node -r ./patch-readlink.js node_modules/next/dist/bin/next build",
    "start": "next start",
    "verify:boundaries": "node scripts/verify-boundaries.mjs",
    "verify:scoring": "tsx scripts/verify-scoring-regression.ts",
    "verify:top3": "tsx scripts/verify-top3-regression.ts",
    "verify:submit": "tsx scripts/verify-submit-validation.ts",
    "verify:storage": "tsx scripts/verify-survey-storage.ts",
    "prebuild": "npm run verify:boundaries && npm run verify:scoring && npm run verify:top3 && npm run verify:submit && npm run verify:storage",
    "smoke:analysis": "python analysis/run_smoke.py --smoke",
    "regenerate:smoke-fixture": "tsx scripts/regenerate-smoke-fixture.ts",
    "generate:question-map": "tsx scripts/generate-question-map.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "next": "^15.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "tailwindcss": "^4.1.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0"
  }
}
