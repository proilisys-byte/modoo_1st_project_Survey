# Supabase 프로젝트 설정 (Project Settings > API 에서 확인)
# 실제 값은 .env.local 파일에 넣으세요. .env.local은 git에 커밋되지 않습니다.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# 진단 리포트 이메일 발송 (Resend — https://resend.com)
# Vercel Environment Variables에도 동일하게 등록하세요 (Production + Preview).
RESEND_API_KEY=re_xxxxxxxx
# Resend에서 도메인(proali.kr) 인증 후 사용. 예: PRO ALI SMART <noreply@survey.proali.kr>
EMAIL_FROM=PRO ALI SMART <onboarding@resend.dev>

# 서버 전용 (Vercel Environment Variables — Production + Preview)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
ADMIN_EXPORT_SECRET=your-export-bearer-secret
